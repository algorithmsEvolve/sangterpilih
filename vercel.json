{
    "version": 2,
    "builds": [
        {
            "src": "public/index.php",
            "use": "vercel-php@0.6.0"
        }
    ],
    "rewrites": [
        {
            "source": "/((?!images|css|js|favicon.ico|robots.txt).*)",
            "destination": "/public/index.php"
        }
    ]
}
